<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Google Java Style をベースに、このプロジェクト向けに調整したルールセット。
  - インデント: 4スペース（Javaデファクト）
  - Javadoc必須ルールは無効（内部プロジェクトのため）
-->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <!-- ファイル末尾の改行 -->
  <module name="NewlineAtEndOfFile"/>

  <!-- タブ文字の禁止 -->
  <module name="FileTabCharacter">
    <property name="eachLine" value="true"/>
  </module>

  <!-- 行末の空白 -->
  <module name="RegexpSingleline">
    <property name="format" value="\s+$"/>
    <property name="minimum" value="0"/>
    <property name="maximum" value="0"/>
    <property name="message" value="Line has trailing spaces."/>
  </module>

  <!-- 行の長さ（Checker直下に置く必要あり） -->
  <module name="LineLength">
    <property name="fileExtensions" value="java"/>
    <property name="max" value="120"/>
    <!-- @Query アノテーション内の JPQL は除外 -->
    <property name="ignorePattern" value="^package.*|^import.*|^\s+\@Query.*|a href|href|http://|https://|ftp://"/>
  </module>

  <module name="TreeWalker">

    <!-- インポート -->
    <module name="AvoidStarImport"/>
    <module name="UnusedImports"/>
    <module name="RedundantImport"/>
    <module name="IllegalImport"/>

    <!-- ネーミング規約 -->
    <module name="TypeName"/>
    <module name="MethodName"/>
    <module name="ParameterName"/>
    <module name="LocalVariableName"/>
    <module name="MemberName"/>
    <module name="ConstantName"/>
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>

    <!-- ブロックと波括弧 -->
    <module name="NeedBraces"/>
    <module name="LeftCurly"/>
    <module name="RightCurly"/>
    <module name="EmptyBlock">
      <property name="option" value="text"/>
    </module>

    <!-- 空白 -->
    <module name="WhitespaceAround">
      <property name="allowEmptyConstructors" value="true"/>
      <property name="allowEmptyLambdas" value="true"/>
      <property name="allowEmptyMethods" value="true"/>
      <property name="allowEmptyTypes" value="true"/>
      <property name="allowEmptyLoops" value="true"/>
      <property name="ignoreEnhancedForColon" value="false"/>
    </module>
    <!-- DOT は除外（メソッドチェーンの改行パターン .method() を許容するため） -->
    <module name="NoWhitespaceBefore">
      <property name="tokens" value="SEMI,POST_DEC,POST_INC"/>
    </module>

    <!-- インデント（4スペース） -->
    <module name="Indentation">
      <property name="basicOffset" value="4"/>
      <property name="braceAdjustment" value="0"/>
      <property name="caseIndent" value="4"/>
      <property name="throwsIndent" value="8"/>
      <property name="lineWrappingIndentation" value="8"/>
      <property name="arrayInitIndent" value="4"/>
    </module>

    <!-- 修飾子の順序 -->
    <module name="ModifierOrder"/>
    <module name="RedundantModifier"/>

    <!-- コードの複雑さ -->
    <module name="MethodLength">
      <property name="max" value="80"/>
    </module>
    <module name="ParameterNumber">
      <property name="max" value="7"/>
    </module>

    <!-- その他のコーディングルール -->
    <module name="EmptyStatement"/>
    <module name="EqualsHashCode"/>
    <module name="MissingSwitchDefault"/>
    <module name="SimplifyBooleanExpression"/>
    <module name="SimplifyBooleanReturn"/>
    <module name="StringLiteralEquality"/>
    <module name="NestedTryDepth"/>
    <module name="SuperClone"/>
    <module name="SuperFinalize"/>
    <module name="CovariantEquals"/>
    <module name="DefaultComesLast"/>
    <module name="FallThrough"/>
    <module name="MultipleVariableDeclarations"/>
    <module name="OneStatementPerLine"/>

    <!-- アノテーション -->
    <module name="MissingOverride"/>

  </module>
</module>
